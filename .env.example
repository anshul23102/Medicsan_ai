# Copy this file to .env and fill in the values before running the app.
# .env is listed in .gitignore and must never be committed.

# Flask session signing key.
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
# If this variable is not set, a random key is generated at startup,
# which invalidates all user sessions every time the server restarts.
SECRET_KEY=change-me-to-a-long-random-string

# Groq API key for AI-powered medicine lookups.
# Obtain from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
